POSTGRES_DB=snapcapsule
POSTGRES_USER=snapcapsule
POSTGRES_PASSWORD=change-this-password

HOST_POSTGRES_DATA_DIR=/DATA/AppData/snapcapsule/postgres
HOST_REDIS_DATA_DIR=/DATA/AppData/snapcapsule/redis
HOST_RAW_MEDIA_DIR=/DATA/AppData/snapcapsule/raw
HOST_THUMBNAIL_DIR=/DATA/AppData/snapcapsule/thumbnails
HOST_INGEST_DIR=/DATA/AppData/snapcapsule/ingest

WEBUI_PORT=3000
SNAPCAPSULE_API_WORKERS=2
WORKER_CONCURRENCY=2
SNAPCAPSULE_ALLOWED_ORIGINS=

SNAPCAPSULE_BACKEND_IMAGE=ghcr.io/replace-me/snapcapsule-backend:latest
SNAPCAPSULE_WEB_IMAGE=ghcr.io/replace-me/snapcapsule-web:latest
