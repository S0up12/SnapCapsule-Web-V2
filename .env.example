POSTGRES_DB=snapcapsule
POSTGRES_USER=snapcapsule
POSTGRES_PASSWORD=snapcapsule
SNAPCAPSULE_DB_PORT=5432
SNAPCAPSULE_REDIS_PORT=6379

HOST_POSTGRES_DATA_DIR=postgres_data
HOST_RAW_MEDIA_DIR=./data/raw
HOST_THUMBNAIL_DIR=./data/thumbnails
HOST_INGEST_DIR=./data/ingest

SNAPCAPSULE_API_PORT=8000
SNAPCAPSULE_WEB_PORT=3000
SNAPCAPSULE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
SNAPCAPSULE_DATABASE_URL=postgresql+psycopg://snapcapsule:snapcapsule@127.0.0.1:5432/snapcapsule
SNAPCAPSULE_REDIS_URL=redis://127.0.0.1:6379/0
WORKER_CONCURRENCY=2
